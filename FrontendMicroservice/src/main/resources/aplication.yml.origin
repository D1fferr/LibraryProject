spring:
  application:
    name: FrontendMicroservice
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 15MB
      file-size-threshold: 2KB
server:
  port: 8089
  forward-headers-strategy: framework
external:
  services:
    api-gateway: ${GATEWAY_URL:http://localhost:8080}